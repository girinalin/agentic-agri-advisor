{
  "type": "card",
  "titleKey": "market.title",
  "theme": "market",
  "components": [
    {
      "type": "header",
      "titleKey": "market.title",
      "subtitleKey": "market.subtitle"
    },
    {
      "type": "form",
      "fields": [
        {
          "type": "select",
          "name": "mandi_selector",
          "labelKey": "market.mandi.label",
          "options": [
            {"value": "Nagpur District", "label": "Nagpur Mandi"},
            {"value": "Pune District", "label": "Pune Mandi"},
            {"value": "Indore District", "label": "Indore Mandi"},
            {"value": "Rift Valley Region", "label": "Eldoret Mandi (Kenya)"}
          ]
        }
      ]
    },
    {
      "type": "grid",
      "columns": 3,
      "items": [
        {
          "type": "metric",
          "labelKey": "market.local.wheat",
          "value": "₹2,450/quintal",
          "valueKey": "market.local.wheat.val",
          "status": "optimal"
        },
        {
          "type": "metric",
          "labelKey": "market.local.corn",
          "value": "₹1,980/quintal",
          "valueKey": "market.local.corn.val",
          "status": "optimal"
        },
        {
          "type": "metric",
          "labelKey": "market.local.soy",
          "value": "₹4,200/quintal",
          "valueKey": "market.local.soy.val",
          "status": "warning"
        }
      ]
    },
    {
      "type": "grid",
      "columns": 3,
      "items": [
        {
          "type": "metric",
          "labelKey": "market.cbot.corn",
          "value": "$4.43",
          "status": "optimal"
        },
        {
          "type": "metric",
          "labelKey": "market.cbot.wheat",
          "value": "$6.00",
          "status": "warning"
        },
        {
          "type": "metric",
          "labelKey": "market.cbot.soy",
          "value": "$11.54",
          "status": "optimal"
        }
      ]
    },
    {
      "type": "button",
      "labelKey": "market.exportAnalysis",
      "action": "export_market"
    }
  ]
}