{
  "type": "card",
  "titleKey": "sim.title",
  "theme": "simulation",
  "components": [
    {
      "type": "text",
      "valueKey": "sim.desc"
    },
    {
      "type": "grid",
      "columns": 5,
      "items": [
        {
          "type": "metric",
          "labelKey": "sim.day",
          "value": "Day 0",
          "status": "normal"
        },
        {
          "type": "metric",
          "labelKey": "sim.stage",
          "value": "germination",
          "status": "normal"
        },
        {
          "type": "metric",
          "labelKey": "sim.moisture",
          "value": "40%",
          "status": "optimal"
        },
        {
          "type": "metric",
          "labelKey": "sim.health",
          "value": "100%",
          "status": "optimal"
        },
        {
          "type": "metric",
          "labelKey": "sim.pest",
          "value": "5.0%",
          "status": "optimal"
        }
      ]
    },
    {
      "type": "form",
      "fields": [
        {
          "type": "select",
          "name": "crop_type",
          "labelKey": "sim.cropSelector.label",
          "options": [
            "sim.crop.corn",
            "sim.crop.wheat",
            "sim.crop.soybeans"
          ]
        },
        {
          "type": "input",
          "name": "water_liters",
          "labelKey": "sim.water.label",
          "placeholder": "10.0"
        },
        {
          "type": "input",
          "name": "fertilizer_kg",
          "labelKey": "sim.fertilizer.label",
          "placeholder": "5.0"
        }
      ]
    },
    {
      "type": "button",
      "labelKey": "sim.stepAction",
      "action": "run_sim_step"
    }
  ]
}