@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ag: <http://antigravity.google/schema/agri#> .

# Classes
ag:Crop rdf:type owl:Class ;
    rdfs:label "Crop" ;
    rdfs:comment "Represents an agricultural crop." .

ag:SoilCondition rdf:type owl:Class ;
    rdfs:label "Soil Condition" ;
    rdfs:comment "Chemical and physical state of a soil sample." .

# Properties
ag:requiresNPK rdf:type owl:ObjectProperty ;
    rdfs:domain ag:Crop ;
    rdfs:range ag:SoilCondition ;
    rdfs:label "requires NPK" .
